# Copy to `.env` and adjust for your deployment.
# `docker compose` reads `.env` automatically.

# -- Host port to publish on.
# 22 means visitors can connect with simply `ssh <your-domain>`.
# This requires port 22 on the host to be free (move your admin sshd to
# another port, e.g. 22022, if needed).
# For local development or shared hosts use a high port like 2222.
SSH_PORT=22

# Maximum concurrent SSH sessions before new ones are refused with a polite
# banner. The portfolio is read-only, but each session keeps an Ink React
# tree in memory, so this prevents abuse from exhausting the box.
MAX_CONNECTIONS=50

# Idle disconnect timeout (milliseconds). Visitors that send no input for
# this long are gracefully kicked. Default: 15 minutes.
IDLE_TIMEOUT_MS=900000
