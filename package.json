{
  "name": "portfolio-ssh",
  "version": "1.0.0",
  "description": "Pablo Vallejo's interactive portfolio served over SSH (Node.js + React Ink + TypeScript)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "portfolio-ssh": "./dist/server.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "figlet": "^1.7.0",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "@types/ssh2": "^1.15.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "esbuild",
      "ssh2"
    ]
  }
}
